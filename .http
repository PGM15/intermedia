@baseUrl = http://localhost:3000
@accessToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2E5NGMyOGQzOTExY2FiM2I5YjFmOCIsImlhdCI6MTc3NDg4NDAzNCwiZXhwIjoxNzc0ODg0OTM0fQ.aDMoxSIMU_w01MxRLIlywwVsfHc2kzi84sI90bH4wfA
@refreshToken = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5Y2E5NGMyOGQzOTExY2FiM2I5YjFmOCIsImlhdCI6MTc3NDg4NDAzNCwiZXhwIjoxNzc1NDg4ODM0fQ.e-49G-MGK--GGUXK6N4I7-i7qjM7U56Gn385RB9wtt0
@verificationCode = 780234

### Health check
GET {{baseUrl}}/api/health

### ------------------------------------------------------------
### 1) REGISTER
### Crea un usuario nuevo
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/register
Content-Type: application/json

{
  "email": "cjb6@test.com",
  "password": "123456"
}

### ------------------------------------------------------------
### 2) VALIDATION
### ------------------------------------------------------------
PUT {{baseUrl}}/api/user/validation
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "{{verificationCode}}"
}

### ------------------------------------------------------------
### 3) LOGIN
### Solo funciona si el usuario ya está validado
### IMPORTANTE:
### - copia el accessToken de la respuesta en @accessToken
### - copia el refreshToken de la respuesta en @refreshToken
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/login
Content-Type: application/json

{
  "email": "cjb6@test.com",
  "password": "123456"
}

### ------------------------------------------------------------
### 4) GET CURRENT USER
### Devuelve el usuario autenticado
### ------------------------------------------------------------
GET {{baseUrl}}/api/user
Authorization: Bearer {{accessToken}}

### ------------------------------------------------------------
### 5) COMPLETE PROFILE / ONBOARDING PERSONAL
### PUT /api/user/register
### Completa datos personales del usuario
### ------------------------------------------------------------
PUT {{baseUrl}}/api/user/register
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Pablo",
  "lastName": "González Mediavilla",
  "nif": "12345678Z",
  "address": {
    "street": "Calle Mayor 12",
    "city": "Madrid",
    "postalCode": "28001",
    "country": "España"
  }
}

### ------------------------------------------------------------
### 6) ASSIGN COMPANY - EMPRESA NUEVA
### Si el CIF no existe, crea la company y deja al usuario como admin
### ------------------------------------------------------------
PATCH {{baseUrl}}/api/user/company
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "isFreelance": false,
  "name": "Mi Empresa SL",
  "cif": "B1345678",
  "address": {
    "street": "Gran Via 20",
    "city": "Madrid",
    "postalCode": "28013",
    "country": "España"
  }
}

### ------------------------------------------------------------
### 7) ASSIGN COMPANY - UNIRSE A EMPRESA EXISTENTE
### Usa otro usuario distinto pero el mismo CIF
### Ese usuario debería quedar como guest
### ------------------------------------------------------------
PATCH {{baseUrl}}/api/user/company
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "isFreelance": false,
  "name": "Mi Empresa SL",
  "cif": "B12345678",
  "address": {
    "street": "Gran Via 20",
    "city": "Madrid",
    "postalCode": "28013",
    "country": "España"
  }
}

### ------------------------------------------------------------
### 8) ASSIGN COMPANY - AUTÓNOMO
### Requiere haber completado antes el perfil personal
### ------------------------------------------------------------
PATCH {{baseUrl}}/api/user/company
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "isFreelance": true
}

### ------------------------------------------------------------
### 9) GET CURRENT USER OTRA VEZ
### ------------------------------------------------------------
GET {{baseUrl}}/api/user
Authorization: Bearer {{accessToken}}

### -----------------------------
### 10) Subir un logo de la empresa
### Hay que probarlo en Postman
### ------------------------------

### ------------------------------------------------------------
### 11) REFRESH SESSION
### Envía el refresh token y debe devolver un nuevo accessToken
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### ------------------------------------------------------------
### 12) LOGOUT
### Requiere access token + refresh token
### Debe invalidar el refresh token guardado
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/logout
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### ------------------------------------------------------------
### 13) REFRESH DESPUÉS DE LOGOUT
### Debe fallar con 401 porque el refresh token ya no es válido
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}
### ------------------------------------------------------------
### 14) DELETE USER - SOFT DELETE
### Debe marcar deleted=true y anular refreshToken
### ------------------------------------------------------------
DELETE {{baseUrl}}/api/user?soft=true
Authorization: Bearer {{accessToken}}
### ------------------------------------------------------------
### 15) DELETE USER - HARD DELETE
### Debe borrar el documento físicamente
### ------------------------------------------------------------
DELETE {{baseUrl}}/api/user
Authorization: Bearer {{accessToken}}
### ------------------------------------------------------------
### 16) INVITE USER
### Solo admin puede invitar
### Crea un usuario guest en la misma company del admin
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/invite
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "email": "invitado1@test.com",
  "password": "12345678"
}
### ------------------------------------------------------------
### 17) CHANGE PASSWORD
### Requiere JWT
### La nueva contraseña debe ser distinta de la actual
### ------------------------------------------------------------
PUT {{baseUrl}}/api/user/password
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "currentPassword": "12345678",
  "newPassword": "123456789"
}
### ------------------------------------------------------------
### 18) LOGIN CON NUEVA CONTRASEÑA
### Debe funcionar con la nueva contraseña
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/login
Content-Type: application/json

{
  "email": "invitado1@test.com",
  "password": "123456789"
}
### ------------------------------------------------------------
### 19) CHANGE PASSWORD - ERROR MISMA CONTRASEÑA
### Debe fallar por el refine de Zod
### ------------------------------------------------------------
PUT {{baseUrl}}/api/user/password
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "currentPassword": "123456789",
  "newPassword": "123456789"
}