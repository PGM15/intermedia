@baseUrl = http://localhost:3000
@accessToken = PEGA_AQUI_EL_ACCESS_TOKEN
@refreshToken = PEGA_AQUI_EL_REFRESH_TOKEN
@verificationCode = 324368

### Health check
GET {{baseUrl}}/api/health

### ------------------------------------------------------------
### 1) REGISTER
### Crea un usuario nuevo
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/register
Content-Type: application/json

{
  "email": "cjb1@test.com",
  "password": "123456"
}

### ------------------------------------------------------------
### 2) VALIDATION
### ------------------------------------------------------------
PUT {{baseUrl}}/api/user/validation
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "code": "{{verificationCode}}"
}

### ------------------------------------------------------------
### 3) LOGIN
### Solo funciona si el usuario ya está validado
### IMPORTANTE:
### - copia el accessToken de la respuesta en @accessToken
### - copia el refreshToken de la respuesta en @refreshToken
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/login
Content-Type: application/json

{
  "email": "cjb@test.com",
  "password": "123456"
}

### ------------------------------------------------------------
### 4) GET CURRENT USER
### Devuelve el usuario autenticado
### ------------------------------------------------------------
GET {{baseUrl}}/api/user
Authorization: Bearer {{accessToken}}

### ------------------------------------------------------------
### 5) COMPLETE PROFILE / ONBOARDING PERSONAL
### PUT /api/user/register
### Completa datos personales del usuario
### ------------------------------------------------------------
PUT {{baseUrl}}/api/user/register
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "name": "Pablo",
  "lastName": "González Mediavilla",
  "nif": "12345678Z",
  "address": {
    "street": "Calle Mayor 12",
    "city": "Madrid",
    "postalCode": "28001",
    "country": "España"
  }
}

### ------------------------------------------------------------
### 6) ASSIGN COMPANY - EMPRESA NUEVA
### Si el CIF no existe, crea la company y deja al usuario como admin
### ------------------------------------------------------------
PATCH {{baseUrl}}/api/user/company
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "isFreelance": false,
  "name": "Mi Empresa SL",
  "cif": "B12345678",
  "address": {
    "street": "Gran Via 20",
    "city": "Madrid",
    "postalCode": "28013",
    "country": "España"
  }
}

### ------------------------------------------------------------
### 7) ASSIGN COMPANY - UNIRSE A EMPRESA EXISTENTE
### Usa otro usuario distinto pero el mismo CIF
### Ese usuario debería quedar como guest
### ------------------------------------------------------------
PATCH {{baseUrl}}/api/user/company
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "isFreelance": false,
  "name": "Mi Empresa SL",
  "cif": "B12345678",
  "address": {
    "street": "Gran Via 20",
    "city": "Madrid",
    "postalCode": "28013",
    "country": "España"
  }
}

### ------------------------------------------------------------
### 8) ASSIGN COMPANY - AUTÓNOMO
### Requiere haber completado antes el perfil personal
### ------------------------------------------------------------
PATCH {{baseUrl}}/api/user/company
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "isFreelance": true
}

### ------------------------------------------------------------
### 9) GET CURRENT USER OTRA VEZ
### ------------------------------------------------------------
GET {{baseUrl}}/api/user
Authorization: Bearer {{accessToken}}

### -----------------------------
### 10) Subir un logo de la empresa
### Hay que probarlo en Postman
### ------------------------------

### ------------------------------------------------------------
### 11) REFRESH SESSION
### Envía el refresh token y debe devolver un nuevo accessToken
### Si tu implementación también rota refresh token,
### copia también el nuevo refreshToken en @refreshToken
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### ------------------------------------------------------------
### 12) LOGOUT
### Requiere access token + refresh token
### Debe invalidar el refresh token guardado
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/logout
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### ------------------------------------------------------------
### 13) REFRESH DESPUÉS DE LOGOUT
### Debe fallar con 401 porque el refresh token ya no es válido
### ------------------------------------------------------------
POST {{baseUrl}}/api/user/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}